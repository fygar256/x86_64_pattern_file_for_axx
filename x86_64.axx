/* === E [v10簡約]: SIZE修飾語廃止 + qword check 追加 ===
   BYTE  → j(dst),k(src): AL,CL,DL,BL,SPL,BPL,SIL,DIL,R8B-R15B,AH,CH,DH,BH
   WORD  → n(dst),m(src): AX,CX,DX,BX,SP,BP,SI,DI,R8W-R15W
   DWORD → f(dst),t(src): EAX,ECX,EDX,EBX,ESP,EBP,ESI,EDI,R8D-R15D
   QWORD → d(dst),s(src): RAX,RCX,RDX,RBX,RSP,RBP,RSI,RDI,R8-R15
   ★ 評価順序: d,s はqword専用に制限。32bitはf,t、16bitはn,m、8bitはj,k が先にマッチ ★
   ============================================================= */
.check::j::AL,CL,DL,BL,SPL,BPL,SIL,DIL,R8B,R9B,R10B,R11B,R12B,R13B,R14B,R15B,AH,CH,DH,BH
.check::k::AL,CL,DL,BL,SPL,BPL,SIL,DIL,R8B,R9B,R10B,R11B,R12B,R13B,R14B,R15B,AH,CH,DH,BH
.check::n::AX,CX,DX,BX,SP,BP,SI,DI,R8W,R9W,R10W,R11W,R12W,R13W,R14W,R15W
.check::m::AX,CX,DX,BX,SP,BP,SI,DI,R8W,R9W,R10W,R11W,R12W,R13W,R14W,R15W
.check::f::EAX,ECX,EDX,EBX,ESP,EBP,ESI,EDI,R8D,R9D,R10D,R11D,R12D,R13D,R14D,R15D
.check::t::EAX,ECX,EDX,EBX,ESP,EBP,ESI,EDI,R8D,R9D,R10D,R11D,R12D,R13D,R14D,R15D
.check::d::RAX,RCX,RDX,RBX,RSP,RBP,RSI,RDI,R8,R9,R10,R11,R12,R13,R14,R15
.check::s::RAX,RCX,RDX,RBX,RSP,RBP,RSI,RDI,R8,R9,R10,R11,R12,R13,R14,R15

/* ====================== データ定義 ====================== */
DB !e  ::  ::  e
DW !e  ::  ::  @@[2,*(e,%%)]
DD !e  ::  ::  @@[4,*(e,%%)]
DQ !e  ::  ::  @@[8,*(e,%%)]

/* ====================== [symbol+reg] SIBアドレッシング ====================== */
/*
   disp32 + index*1 (base なし) アドレッシング。
   s を「symbol: .equ addr::abs32」で定義すると、
   4バイトフィールドに R_X86_64_32 リロケーションが生成される。

   符号化:
     REX  : ;((r&8)?0x42:0)  ← REX.X bit のみ (index が r8-r15 のとき)
     opcode: 0xFE / 0x80 など
     ModRM : mod=00, /op, r/m=4(SIB)
     SIB   : scale=00, index=(r&7), base=101(disp32のみ) → ((r&7)<<3)|5
     disp32: @@[4,*(s,%%)]
*/
INC BYTE [!s\+r]      ::  ::  ;((r&8)?0x42:0),0xfe,0x04,((r&7)<<3)|5,@@[4,*(s,%%)]
DEC BYTE [!s\+r]      ::  ::  ;((r&8)?0x42:0),0xfe,0x0c,((r&7)<<3)|5,@@[4,*(s,%%)]
CMP BYTE [!s\+r],!i   ::  ::  ;((r&8)?0x42:0),0x80,0x3c,((r&7)<<3)|5,@@[4,*(s,%%)],(i&0xff)
MOV  j,[!s\+r]    ::  ::  ;((r&8)?0x42:0),0x8a,0x04|((j&7)<<3),((r&7)<<3)|5,@@[4,*(s,%%)]
MOV  [!s\+r],j    ::  ::  ;((r&8)?0x42:0),0x88,0x04|((j&7)<<3),((r&7)<<3)|5,@@[4,*(s,%%)]


/* ====================== MOV セグメントレジスタ ← メモリ (0x8E /r) ====================== */
/* ★ 順序重要: MOV d,[RSP] など汎用パターンより前に配置 ★
   64ビットモードでも全セグメントレジスタへのメモリロードは有効。
   RIP相対、RSP/R12(SIB必須)、RBP/R13(mod=01,disp8=0) 特殊形含む。
   モジュロ: ModRM.reg = sreg番号 (ES=0,CS=1,SS=2,DS=3,FS=4,GS=5)   */

/* === A-1 [v10簡約]: MOV sreg←mem  72→12パターン (.check::g 統合) === */
.check::g::ES,CS,SS,DS,FS,GS
MOV g,[RIP+!a]   ::  ::  0x8e,(g<<3)|0x05,@@[4,*(a-$.,%%)]
MOV g,[RSP]      ::  ::  0x8e,(g<<3)|0x04,0x24
MOV g,[R12]      ::  ::  0x41,0x8e,(g<<3)|0x04,0x24
MOV g,[RBP]      ::  ::  0x8e,0x40|(g<<3)|0x05,0x00
MOV g,[R13]      ::  ::  0x41,0x8e,0x40|(g<<3)|0x05,0x00
MOV g,[b]        ::  ::  ;((b&8)?0x41:0),0x8e,(g<<3)|(b&7)
MOV g,[RSP+!o]B  ::  ::  0x8e,0x40|(g<<3)|0x04,0x24,(o&0xff)
MOV g,[R12+!o]B  ::  ::  0x41,0x8e,0x40|(g<<3)|0x04,0x24,(o&0xff)
MOV g,[b+!o]B    ::  ::  ;((b&8)?0x41:0),0x8e,0x40|(g<<3)|(b&7),(o&0xff)
MOV g,[RSP+!o]   ::  ::  0x8e,0x80|(g<<3)|0x04,0x24,@@[4,*(o,%%)]
MOV g,[R12+!o]   ::  ::  0x41,0x8e,0x80|(g<<3)|0x04,0x24,@@[4,*(o,%%)]
MOV g,[b+!o]     ::  ::  ;((b&8)?0x41:0),0x8e,0x80|(g<<3)|(b&7),@@[4,*(o,%%)]
.clrcheck::g

/* ====================== RSP/R12 ベース: SIB=0x24 必要 ====================== */
/* RSP(4)/R12(12) が rm=100 のとき CPU は SIB バイトを期待する。
   SIB=0x24: scale=00, index=100(none), base=100(RSP/R12)
   R12: REX.B=1 で base=100 → R12 を指す。                            */
/* 64bit load */
MOV d,[RSP]             ::  ::  0x48|((d&8)>>1),0x8b,((d&7)<<3)|0x04,0x24
MOV d,[RSP+!o]B         ::  ::  0x48|((d&8)>>1),0x8b,0x40|((d&7)<<3)|0x04,0x24,(o&0xff)
MOV d,[RSP+!o]          ::  ::  0x48|((d&8)>>1),0x8b,0x80|((d&7)<<3)|0x04,0x24,@@[4,*(o,%%)]
MOV d,[R12]             ::  ::  0x49|((d&8)>>1),0x8b,((d&7)<<3)|0x04,0x24
MOV d,[R12+!o]B         ::  ::  0x49|((d&8)>>1),0x8b,0x40|((d&7)<<3)|0x04,0x24,(o&0xff)
MOV d,[R12+!o]          ::  ::  0x49|((d&8)>>1),0x8b,0x80|((d&7)<<3)|0x04,0x24,@@[4,*(o,%%)]
/* 64bit store */
MOV [RSP],s             ::  ::  0x48|((s&8)>>1),0x89,((s&7)<<3)|0x04,0x24
MOV [RSP+!o]B,s         ::  ::  0x48|((s&8)>>1),0x89,0x40|((s&7)<<3)|0x04,0x24,(o&0xff)
MOV [RSP+!o],s          ::  ::  0x48|((s&8)>>1),0x89,0x80|((s&7)<<3)|0x04,0x24,@@[4,*(o,%%)]
MOV [R12],s             ::  ::  0x49|((s&8)>>1),0x89,((s&7)<<3)|0x04,0x24
MOV [R12+!o]B,s         ::  ::  0x49|((s&8)>>1),0x89,0x40|((s&7)<<3)|0x04,0x24,(o&0xff)
MOV [R12+!o],s          ::  ::  0x49|((s&8)>>1),0x89,0x80|((s&7)<<3)|0x04,0x24,@@[4,*(o,%%)]
/* 64bit immediate */
MOV QWORD [RSP],!i      ::  ::  0x48,0xc7,0x04,0x24,@@[4,*(i,%%)]
MOV QWORD [RSP+!o]B,!i  ::  ::  0x48,0xc7,0x44,0x24,(o&0xff),@@[4,*(i,%%)]
MOV QWORD [RSP+!o],!i   ::  ::  0x48,0xc7,0x84,0x24,@@[4,*(o,%%)],@@[4,*(i,%%)]
MOV QWORD [R12],!i      ::  ::  0x49,0xc7,0x04,0x24,@@[4,*(i,%%)]
MOV QWORD [R12+!o]B,!i  ::  ::  0x49,0xc7,0x44,0x24,(o&0xff),@@[4,*(i,%%)]
MOV QWORD [R12+!o],!i   ::  ::  0x49,0xc7,0x84,0x24,@@[4,*(o,%%)],@@[4,*(i,%%)]

/* ====================== RBP/R13 ベース: mod=00 は RIP相対になるので mod=01,disp8=0 を使う ====================== */
/* mod=00, rm=101 → disp32(RIP相対)。RBP/R13 間接参照は mod=01, disp8=0x00 が正しい。 */
MOV d,[RBP]             ::  ::  0x48|((d&8)>>1),0x8b,0x40|((d&7)<<3)|0x05,0x00
MOV d,[R13]             ::  ::  0x49|((d&8)>>1),0x8b,0x40|((d&7)<<3)|0x05,0x00
MOV [RBP],s             ::  ::  0x48|((s&8)>>1),0x89,0x40|((s&7)<<3)|0x05,0x00
MOV [R13],s             ::  ::  0x49|((s&8)>>1),0x89,0x40|((s&7)<<3)|0x05,0x00
MOV QWORD [RBP],!i      ::  ::  0x48,0xc7,0x45,0x00,@@[4,*(i,%%)]
MOV QWORD [R13],!i      ::  ::  0x49,0xc7,0x45,0x00,@@[4,*(i,%%)]

/* ====================== SIBスケールドアドレッシング [base+index*scale] ====================== */
/* scale=2(01)/4(10)/8(11), SIB = (ss<<6)|((r&7)<<3)|(b&7)
   mod=00: disp なし, mod=01: disp8, mod=10: disp32
   REX: W=1固定, R=d>>3, X=r>>3(index), B=b>>3(base)                  */


/* --- [b+r*1] scale=1, SIB.ss=00 --- */
MOV d,[b+r*!!h]           ::  ::  0x48|((d&8)>>1)|((r&8)>>2)|((b&8)>>3),0x8b,0x04|((d&7)<<3),((@h-1)<<6|((r&7)<<3)|(b&7))
MOV d,[b+r*!!h+!o]B       ::  ::  0x48|((d&8)>>1)|((r&8)>>2)|((b&8)>>3),0x8b,0x44|((d&7)<<3),((@h-1)<<6|((r&7)<<3)|(b&7)),(o&0xff)
MOV d,[b+r*!!h+!o]        ::  ::  0x48|((d&8)>>1)|((r&8)>>2)|((b&8)>>3),0x8b,0x84|((d&7)<<3),((@h-1)<<6|((r&7)<<3)|(b&7)),@@[4,*(o,%%)]
MOV [b+r*!!h],s           ::  ::  0x48|((s&8)>>1)|((r&8)>>2)|((b&8)>>3),0x89,0x04|((s&7)<<3),((@h-1)<<6|((r&7)<<3)|(b&7))
MOV [b+r*!!h+!o]B,s       ::  ::  0x48|((s&8)>>1)|((r&8)>>2)|((b&8)>>3),0x89,0x44|((s&7)<<3),((@h-1)<<6|((r&7)<<3)|(b&7)),(o&0xff)
MOV [b+r*!!h+!o],s        ::  ::  0x48|((s&8)>>1)|((r&8)>>2)|((b&8)>>3),0x89,0x84|((s&7)<<3),((@h-1)<<6|((r&7)<<3)|(b&7)),@@[4,*(o,%%)]
LEA d,[b+r*!!h]           ::  ::  0x48|((d&8)>>1)|((r&8)>>2)|((b&8)>>3),0x8d,0x04|((d&7)<<3),((@h-1)<<6|((r&7)<<3)|(b&7))
LEA d,[b+r*!!h+!o]B       ::  ::  0x48|((d&8)>>1)|((r&8)>>2)|((b&8)>>3),0x8d,0x44|((d&7)<<3),((@h-1)<<6|((r&7)<<3)|(b&7)),(o&0xff)
LEA d,[b+r*!!h+!o]        ::  ::  0x48|((d&8)>>1)|((r&8)>>2)|((b&8)>>3),0x8d,0x84|((d&7)<<3),((@h-1)<<6|((r&7)<<3)|(b&7)),@@[4,*(o,%%)]
ADD d,[b+r*!!h]           ::  ::  0x48|((d&8)>>1)|((r&8)>>2)|((b&8)>>3),0x03,0x04|((d&7)<<3),((@h-1)<<6|((r&7)<<3)|(b&7))
ADD d,[b+r*!!h+!o]B       ::  ::  0x48|((d&8)>>1)|((r&8)>>2)|((b&8)>>3),0x03,0x44|((d&7)<<3),((@h-1)<<6|((r&7)<<3)|(b&7)),(o&0xff)
SUB d,[b+r*!!h]           ::  ::  0x48|((d&8)>>1)|((r&8)>>2)|((b&8)>>3),0x2b,0x04|((d&7)<<3),((@h-1)<<6|((r&7)<<3)|(b&7))
SUB d,[b+r*!!h+!o]B       ::  ::  0x48|((d&8)>>1)|((r&8)>>2)|((b&8)>>3),0x2b,0x44|((d&7)<<3),((@h-1)<<6|((r&7)<<3)|(b&7)),(o&0xff)
CMP d,[b+r*!!h]           ::  ::  0x48|((d&8)>>1)|((r&8)>>2)|((b&8)>>3),0x3b,0x04|((d&7)<<3),((@h-1)<<6|((r&7)<<3)|(b&7))
CMP d,[b+r*!!h+!o]B       ::  ::  0x48|((d&8)>>1)|((r&8)>>2)|((b&8)>>3),0x3b,0x44|((d&7)<<3),((@h-1)<<6|((r&7)<<3)|(b&7)),(o&0xff)
