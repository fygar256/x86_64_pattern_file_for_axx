VMXOFF                  ::  ::  0x0f,0x01,0xc4
SWAPGS                  ::  ::  0x0f,0x01,0xf8

/* ====================== メモリバリア ====================== */
LFENCE                  ::  ::  0x0f,0xae,0xe8
MFENCE                  ::  ::  0x0f,0xae,0xf0
SFENCE                  ::  ::  0x0f,0xae,0xf8
CLFLUSH [b]             ::  ::  ;((b&8)?0x41:0),0x0f,0xae,0x38|(b&7)
CLFLUSHOPT [b]          ::  ::  0x66,;((b&8)?0x41:0),0x0f,0xae,0x38|(b&7)
