/* =========================================================
   v8.0 追加: セグメントオーバーライドアドレッシング
   =========================================================
   セグメントオーバーライドプレフィックスバイト:
     ES=0x26  CS=0x2E  SS=0x36  DS=0x3E  FS=0x64  GS=0x65

   構文: MOV dest, SEG:[base+disp]  /  MOV SEG:[base+disp], src
   パターン変数:
     d = ロード先 64bit レジスタ
     s = ストア元 64bit レジスタ
     b = ベースレジスタ (0–15)
     r = インデックスレジスタ (SIB 用)
     o = ディスプレースメント

   ★ SEG:[...] という構文は既存の [b] 等と構造が異なるため
     ファイル末尾への追加で競合は発生しない ★

   注: 64ビットモードでは FS:/GS: のみ CPU がアドレス変換に使用。
       CS:/SS:/DS:/ES: はプレフィックスは許容されるが CPU に無視される。

   使用例:
     MOV RAX, FS:[RBX]           ; TLS ベースアドレスロード
     MOV GS:[RCX+0x28], RAX      ; GS 相対ストア
     MOV RDX, FS:[RSP+!offset]B  ; FS 相対 disp8 ロード
   ========================================================= */

/* ================================================================
   C [v10簡約]: MOV p:[mem] / MOV [mem],p / DWORD/WORD/BYTE/imm  全6セグ統合
   prefix = (p<4)?(0x26|(p<<3)):(0x60|(p&7))
     ES=0x26 CS=0x2e SS=0x36 DS=0x3e (p=0-3: 算術式)
     FS=0x64 GS=0x65                 (p=4-5: 0x60|(p&7))
   ================================================================ */
.check::p::ES,CS,SS,DS,FS,GS
   ================================================================ */

/* RSP/R12: rm=4 → SIB 必須 (SIB=0x24: scale=0,index=none,base=RSP/R12) */
MOV d,p:[RSP]       ::  ::  (p<4)?(0x26|(p<<3)):(0x60|(p&7)),0x48|((d&8)>>1),0x8b,((d&7)<<3)|0x04,0x24
MOV d,p:[R12]       ::  ::  (p<4)?(0x26|(p<<3)):(0x60|(p&7)),0x49|((d&8)>>1),0x8b,((d&7)<<3)|0x04,0x24
/* RBP/R13: mod=00,rm=5 = RIP相対 → mod=01,disp8=0 を使用 */
MOV d,p:[RBP]       ::  ::  (p<4)?(0x26|(p<<3)):(0x60|(p&7)),0x48|((d&8)>>1),0x8b,0x40|((d&7)<<3)|0x05,0x00
MOV d,p:[R13]       ::  ::  (p<4)?(0x26|(p<<3)):(0x60|(p&7)),0x49|((d&8)>>1),0x8b,0x40|((d&7)<<3)|0x05,0x00
/* 汎用 [b] — disp なし */
MOV d,p:[b]         ::  ::  (p<4)?(0x26|(p<<3)):(0x60|(p&7)),0x48|((d&8)>>1)|((b&8)>>3),0x8b,((d&7)<<3)|(b&7)
/* disp8 形式 */
MOV d,p:[RSP+!o]B   ::  ::  (p<4)?(0x26|(p<<3)):(0x60|(p&7)),0x48|((d&8)>>1),0x8b,0x40|((d&7)<<3)|0x04,0x24,(o&0xff)
MOV d,p:[R12+!o]B   ::  ::  (p<4)?(0x26|(p<<3)):(0x60|(p&7)),0x49|((d&8)>>1),0x8b,0x40|((d&7)<<3)|0x04,0x24,(o&0xff)
MOV d,p:[b+!o]B     ::  ::  (p<4)?(0x26|(p<<3)):(0x60|(p&7)),0x48|((d&8)>>1)|((b&8)>>3),0x8b,0x40|((d&7)<<3)|(b&7),(o&0xff)
/* disp32 形式 */
MOV d,p:[RSP+!o]    ::  ::  (p<4)?(0x26|(p<<3)):(0x60|(p&7)),0x48|((d&8)>>1),0x8b,0x80|((d&7)<<3)|0x04,0x24,@@[4,*(o,%%)]
MOV d,p:[R12+!o]    ::  ::  (p<4)?(0x26|(p<<3)):(0x60|(p&7)),0x49|((d&8)>>1),0x8b,0x80|((d&7)<<3)|0x04,0x24,@@[4,*(o,%%)]
MOV d,p:[b+!o]      ::  ::  (p<4)?(0x26|(p<<3)):(0x60|(p&7)),0x48|((d&8)>>1)|((b&8)>>3),0x8b,0x80|((d&7)<<3)|(b&7),@@[4,*(o,%%)]
/* SIB 形式: [b+r*scale]  scale=1/2/4/8  (ModRM.rm=4, SIBバイト使用) */
MOV d,p:[b+r*!!h]     ::  ::  (p<4)?(0x26|(p<<3)):(0x60|(p&7)),0x48|((d&8)>>1)|((r&8)>>2)|((b&8)>>3),0x8b,0x04|((d&7)<<3),((@h-1)<<6|((r&7)<<3)|(b&7))
MOV d,p:[b+r*!!h+!o]B ::  ::  (p<4)?(0x26|(p<<3)):(0x60|(p&7)),0x48|((d&8)>>1)|((r&8)>>2)|((b&8)>>3),0x8b,0x44|((d&7)<<3),((@h-1)<<6|((r&7)<<3)|(b&7)),(o&0xff)
MOV d,p:[b+r*!!h+!o]  ::  ::  (p<4)?(0x26|(p<<3)):(0x60|(p&7)),0x48|((d&8)>>1)|((r&8)>>2)|((b&8)>>3),0x8b,0x84|((d&7)<<3),((@h-1)<<6|((r&7)<<3)|(b&7)),@@[4,*(o,%%)]

MOV p:[RSP],s       ::  ::  (p<4)?(0x26|(p<<3)):(0x60|(p&7)),0x48|((s&8)>>1),0x89,((s&7)<<3)|0x04,0x24
MOV p:[R12],s       ::  ::  (p<4)?(0x26|(p<<3)):(0x60|(p&7)),0x49|((s&8)>>1),0x89,((s&7)<<3)|0x04,0x24
MOV p:[RBP],s       ::  ::  (p<4)?(0x26|(p<<3)):(0x60|(p&7)),0x48|((s&8)>>1),0x89,0x40|((s&7)<<3)|0x05,0x00
MOV p:[R13],s       ::  ::  (p<4)?(0x26|(p<<3)):(0x60|(p&7)),0x49|((s&8)>>1),0x89,0x40|((s&7)<<3)|0x05,0x00
MOV p:[b],s         ::  ::  (p<4)?(0x26|(p<<3)):(0x60|(p&7)),0x48|((s&8)>>1)|((b&8)>>3),0x89,((s&7)<<3)|(b&7)
MOV p:[RSP+!o]B,s   ::  ::  (p<4)?(0x26|(p<<3)):(0x60|(p&7)),0x48|((s&8)>>1),0x89,0x40|((s&7)<<3)|0x04,0x24,(o&0xff)
MOV p:[R12+!o]B,s   ::  ::  (p<4)?(0x26|(p<<3)):(0x60|(p&7)),0x49|((s&8)>>1),0x89,0x40|((s&7)<<3)|0x04,0x24,(o&0xff)
MOV p:[b+!o]B,s     ::  ::  (p<4)?(0x26|(p<<3)):(0x60|(p&7)),0x48|((s&8)>>1)|((b&8)>>3),0x89,0x40|((s&7)<<3)|(b&7),(o&0xff)
MOV p:[RSP+!o],s    ::  ::  (p<4)?(0x26|(p<<3)):(0x60|(p&7)),0x48|((s&8)>>1),0x89,0x80|((s&7)<<3)|0x04,0x24,@@[4,*(o,%%)]
MOV p:[R12+!o],s    ::  ::  (p<4)?(0x26|(p<<3)):(0x60|(p&7)),0x49|((s&8)>>1),0x89,0x80|((s&7)<<3)|0x04,0x24,@@[4,*(o,%%)]
MOV p:[b+!o],s      ::  ::  (p<4)?(0x26|(p<<3)):(0x60|(p&7)),0x48|((s&8)>>1)|((b&8)>>3),0x89,0x80|((s&7)<<3)|(b&7),@@[4,*(o,%%)]
/* SIB ストア */
MOV p:[b+r*!!h],s     ::  ::  (p<4)?(0x26|(p<<3)):(0x60|(p&7)),0x48|((s&8)>>1)|((r&8)>>2)|((b&8)>>3),0x89,0x04|((s&7)<<3),((@h-1)<<6|((r&7)<<3)|(b&7))
MOV p:[b+r*!!h+!o]B,s ::  ::  (p<4)?(0x26|(p<<3)):(0x60|(p&7)),0x48|((s&8)>>1)|((r&8)>>2)|((b&8)>>3),0x89,0x44|((s&7)<<3),((@h-1)<<6|((r&7)<<3)|(b&7)),(o&0xff)
MOV p:[b+r*!!h+!o],s  ::  ::  (p<4)?(0x26|(p<<3)):(0x60|(p&7)),0x48|((s&8)>>1)|((r&8)>>2)|((b&8)>>3),0x89,0x84|((s&7)<<3),((@h-1)<<6|((r&7)<<3)|(b&7)),@@[4,*(o,%%)]

