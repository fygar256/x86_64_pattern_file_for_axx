   FS: セグメントオーバーライドプレフィックス = 0x64
   ================================================================ */

/* --- MOV r64, FS:[mem]  64ビットロード (プレフィックス=0x64, REX.W=1, opcode=0x8B) --- */
/* RSP/R12: rm=4 → SIB 必須 (SIB=0x24: scale=0,index=none,base=RSP/R12) */
/* RBP/R13: mod=00,rm=5 = RIP相対 → mod=01,disp8=0 を使用 */
/* 汎用 [b] — disp なし */
/* disp8 形式 */
/* disp32 形式 */
/* SIB 形式: [b+r*scale]  scale=1/2/4/8  (ModRM.rm=4, SIBバイト使用) */

/* --- MOV FS:[mem], s  64ビットストア (プレフィックス=0x64, REX.W=1, opcode=0x89) --- */
/* SIB ストア */

/* ================================================================
   GS: セグメントオーバーライドプレフィックス = 0x65
   ================================================================ */

/* RSP/R12: rm=4 → SIB 必須 (SIB=0x24: scale=0,index=none,base=RSP/R12) */
/* RBP/R13: mod=00,rm=5 = RIP相対 → mod=01,disp8=0 を使用 */
/* 汎用 [b] — disp なし */
/* disp8 形式 */
/* disp32 形式 */
/* SIB 形式: [b+r*scale]  scale=1/2/4/8  (ModRM.rm=4, SIBバイト使用) */

/* SIB ストア */

/* =========================================================
   LFS / LGS / LSS — ファーポインタロード (64ビット)
   0F B4/B5/B2 /r  (REX.W=1 で 64ビット汎用レジスタにロード)
   メモリ配置: [mem+0..7]=r64, [mem+8..9]=sreg
   ========================================================= */
/* LFS d,[mem] — r64 と FS を一括ロード */
LFS d,[RSP]      ::  ::  0x48|((d&8)>>1),0x0f,0xb4,((d&7)<<3)|0x04,0x24
LFS d,[R12]      ::  ::  0x49|((d&8)>>1),0x0f,0xb4,((d&7)<<3)|0x04,0x24
LFS d,[RBP]      ::  ::  0x48|((d&8)>>1),0x0f,0xb4,0x40|((d&7)<<3)|0x05,0x00
LFS d,[R13]      ::  ::  0x49|((d&8)>>1),0x0f,0xb4,0x40|((d&7)<<3)|0x05,0x00
LFS d,[b]        ::  ::  0x48|((d&8)>>1)|((b&8)>>3),0x0f,0xb4,((d&7)<<3)|(b&7)
LFS d,[RSP+!o]B  ::  ::  0x48|((d&8)>>1),0x0f,0xb4,0x40|((d&7)<<3)|0x04,0x24,(o&0xff)
LFS d,[R12+!o]B  ::  ::  0x49|((d&8)>>1),0x0f,0xb4,0x40|((d&7)<<3)|0x04,0x24,(o&0xff)
LFS d,[b+!o]B    ::  ::  0x48|((d&8)>>1)|((b&8)>>3),0x0f,0xb4,0x40|((d&7)<<3)|(b&7),(o&0xff)
LFS d,[RSP+!o]   ::  ::  0x48|((d&8)>>1),0x0f,0xb4,0x80|((d&7)<<3)|0x04,0x24,@@[4,*(o,%%)]
LFS d,[R12+!o]   ::  ::  0x49|((d&8)>>1),0x0f,0xb4,0x80|((d&7)<<3)|0x04,0x24,@@[4,*(o,%%)]
LFS d,[b+!o]     ::  ::  0x48|((d&8)>>1)|((b&8)>>3),0x0f,0xb4,0x80|((d&7)<<3)|(b&7),@@[4,*(o,%%)]

/* LGS d,[mem] — r64 と GS を一括ロード */
LGS d,[RSP]      ::  ::  0x48|((d&8)>>1),0x0f,0xb5,((d&7)<<3)|0x04,0x24
LGS d,[R12]      ::  ::  0x49|((d&8)>>1),0x0f,0xb5,((d&7)<<3)|0x04,0x24
LGS d,[RBP]      ::  ::  0x48|((d&8)>>1),0x0f,0xb5,0x40|((d&7)<<3)|0x05,0x00
LGS d,[R13]      ::  ::  0x49|((d&8)>>1),0x0f,0xb5,0x40|((d&7)<<3)|0x05,0x00
LGS d,[b]        ::  ::  0x48|((d&8)>>1)|((b&8)>>3),0x0f,0xb5,((d&7)<<3)|(b&7)
LGS d,[RSP+!o]B  ::  ::  0x48|((d&8)>>1),0x0f,0xb5,0x40|((d&7)<<3)|0x04,0x24,(o&0xff)
LGS d,[R12+!o]B  ::  ::  0x49|((d&8)>>1),0x0f,0xb5,0x40|((d&7)<<3)|0x04,0x24,(o&0xff)
LGS d,[b+!o]B    ::  ::  0x48|((d&8)>>1)|((b&8)>>3),0x0f,0xb5,0x40|((d&7)<<3)|(b&7),(o&0xff)
LGS d,[RSP+!o]   ::  ::  0x48|((d&8)>>1),0x0f,0xb5,0x80|((d&7)<<3)|0x04,0x24,@@[4,*(o,%%)]
LGS d,[R12+!o]   ::  ::  0x49|((d&8)>>1),0x0f,0xb5,0x80|((d&7)<<3)|0x04,0x24,@@[4,*(o,%%)]
LGS d,[b+!o]     ::  ::  0x48|((d&8)>>1)|((b&8)>>3),0x0f,0xb5,0x80|((d&7)<<3)|(b&7),@@[4,*(o,%%)]

/* LSS d,[mem] — r64 と SS を一括ロード */
LSS d,[RSP]      ::  ::  0x48|((d&8)>>1),0x0f,0xb2,((d&7)<<3)|0x04,0x24
LSS d,[R12]      ::  ::  0x49|((d&8)>>1),0x0f,0xb2,((d&7)<<3)|0x04,0x24
