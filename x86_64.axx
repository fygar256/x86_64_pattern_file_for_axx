/* =========================================================

/* ================================================================
   C [v10簡約]: FS/GS セグメントオーバーライド文字列命令  2セグ統合
   prefix = 0x60|(p&7)  (FS=0x64, GS=0x65)
   ================================================================ */
.check::p::FS,GS
   =========================================================
   FS/GS オーバーライドでソースレジスタ (RSI) のセグメントを変更。
   デスティネーション (RDI) は ES: (64ビットモードでは常に線形)。
   書式: [REP] SEG MOVSB/MOVSW/MOVSD/MOVSQ など
   ========================================================= */

/* FS: セグメントオーバーライド文字列命令 */
MOV n,p:[RSP]       ::  ::  (p<4)?(0x26|(p<<3)):(0x60|(p&7)),0x66,;((n&8)?0x44:0),0x8b,((n&7)<<3)|4,0x24
MOV n,p:[R12]       ::  ::  (p<4)?(0x26|(p<<3)):(0x60|(p&7)),0x66,0x41|((n&8)>>1),0x8b,((n&7)<<3)|4,0x24
MOV n,p:[RBP]       ::  ::  (p<4)?(0x26|(p<<3)):(0x60|(p&7)),0x66,;((n&8)?0x44:0),0x8b,0x40|((n&7)<<3)|5,0x00
MOV n,p:[R13]       ::  ::  (p<4)?(0x26|(p<<3)):(0x60|(p&7)),0x66,0x41|((n&8)>>1),0x8b,0x40|((n&7)<<3)|5,0x00
MOV n,p:[b]         ::  ::  (p<4)?(0x26|(p<<3)):(0x60|(p&7)),0x66,;(((n|b)&8)?(0x40|((n&8)>>1)|((b&8)>>3)):0),0x8b,((n&7)<<3)|(b&7)
MOV n,p:[b+!o]B     ::  ::  (p<4)?(0x26|(p<<3)):(0x60|(p&7)),0x66,;(((n|b)&8)?(0x40|((n&8)>>1)|((b&8)>>3)):0),0x8b,0x40|((n&7)<<3)|(b&7),(o&0xff)
MOV n,p:[b+!o]      ::  ::  (p<4)?(0x26|(p<<3)):(0x60|(p&7)),0x66,;(((n|b)&8)?(0x40|((n&8)>>1)|((b&8)>>3)):0),0x8b,0x80|((n&7)<<3)|(b&7),@@[4,*(o,%%)]

