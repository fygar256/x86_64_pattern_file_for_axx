/* ===== オペランドなし命令 (D9 mod=11 など) ===== */
FWAIT    ::  ::  0x9b               /* FPU/CPU 同期 */
FNOP     ::  ::  0xd9,0xd0
FCHS     ::  ::  0xd9,0xe0          /* ST(0) 符号反転 */
FABS     ::  ::  0xd9,0xe1          /* ST(0) 絶対値 */
FTST     ::  ::  0xd9,0xe4          /* ST(0) と +0.0 比較 */
FXAM     ::  ::  0xd9,0xe5          /* ST(0) クラス検査 */
FLD1     ::  ::  0xd9,0xe8          /* ST(0) ← +1.0 */
FLDL2T   ::  ::  0xd9,0xe9          /* ST(0) ← log2(10) */
FLDL2E   ::  ::  0xd9,0xea          /* ST(0) ← log2(e) */
FLDPI    ::  ::  0xd9,0xeb          /* ST(0) ← π */
FLDLG2   ::  ::  0xd9,0xec          /* ST(0) ← log10(2) */
FLDLN2   ::  ::  0xd9,0xed          /* ST(0) ← ln(2) */
FLDZ     ::  ::  0xd9,0xee          /* ST(0) ← +0.0 */
F2XM1    ::  ::  0xd9,0xf0          /* ST(0) ← 2^ST(0)-1 */
FYL2X    ::  ::  0xd9,0xf1          /* ST(1) ← ST(1)*log2(ST(0)), pop */
FPTAN    ::  ::  0xd9,0xf2          /* tan(ST(0)), push 1.0 */
FPATAN   ::  ::  0xd9,0xf3          /* ST(1) ← atan(ST(1)/ST(0)), pop */
FXTRACT  ::  ::  0xd9,0xf4          /* 指数・仮数分離 */
FPREM1   ::  ::  0xd9,0xf5          /* IEEE余剰 */
FDECSTP  ::  ::  0xd9,0xf6          /* スタックポインタ-- */
FINCSTP  ::  ::  0xd9,0xf7          /* スタックポインタ++ */
FPREM    ::  ::  0xd9,0xf8          /* 余剰 (8087互換) */
FYL2XP1  ::  ::  0xd9,0xf9          /* ST(1)*log2(ST(0)+1) */
FSQRT    ::  ::  0xd9,0xfa          /* √ST(0) */
FSINCOS  ::  ::  0xd9,0xfb          /* sin/cos 同時計算 */
FRNDINT  ::  ::  0xd9,0xfc          /* 整数に丸め */
