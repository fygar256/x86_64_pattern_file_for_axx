/* --- QWORD 絶対アドレス即値ストア (SIB abs32: mod=00, index=none, base=disp32) ---
   MOV QWORD [abs32],imm32(符号拡張)
   REX.W(0x48) + C7 /0 + ModRM(00 000 100)=0x04 + SIB(00 100 101)=0x25 + abs32 + imm32
   注: 64ビットモードで [0x1234] のような絶対アドレス指定には SIB abs32 形式を使用。
