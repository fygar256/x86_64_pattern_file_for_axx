/* ========================================
   x86_64 完全パターンファイル for axx  v10.0 (簡約化版) (x87 FPU 完全版 + DWORD/WORD/BYTE セグメントオーバーライド)
   全アドレッシングモード+セグメントオーバーライド対応版

   追加 (v9.0):
     x87 FPU 完全版:
       FLD/FST/FSTP (DWORD/QWORD/TBYTE, register ST0-ST7)
       FADD/FSUB/FMUL/FDIV/FADDP/FSUBP/FMULP/FDIVP (全変形)
       FIADD/FISUB/FIMUL/FIDIV (WORD/DWORD)
       FCOM/FCOMP/FCOMPP/FUCOM/FUCOMPP (比較)
       FCOMI/FUCOMI/FCOMIP/FUCOMIP (EFLAGS設定比較)
       FCMOVxx ST0,STi (条件付き移動、8種)
       FILD/FIST/FISTP/FISTTP (WORD/DWORD/QWORD)
       FICOM/FICOMP/FBLD/FBSTP (整数・BCD)
       FLDCW/FNSTCW/FSTCW/FNSTSW/FSTSW/FNSTSW AX
       FLDENV/FNSTENV/FSTENV/FNSAVE/FSAVE/FRSTOR
       FCHS/FABS/FSQRT/FSIN/FCOS/FSINCOS/FPTAN/FPATAN
       F2XM1/FYL2X/FYL2XP1/FPREM/FPREM1/FRNDINT/FSCALE
       FXTRACT/FLD1/FLDLxxx/FLDZ/FWAIT/FNCLEX/FINIT 等
     セグメントオーバーライド DWORD/WORD/BYTE MOV (ロード+ストア)
     セグメントオーバーライド即値ストア (QWORD/DWORD/WORD/BYTE)
     セグメントオーバーライド文字列命令 (FS/GS × 20命令 + REP/REPE/REPNE)

   追加 (v8.0):
     セグメントアドレッシング完全対応:
     MOV sreg,r / MOV r,sreg  (0x8E/0x8C, ± REX.B)
     MOV sreg,[mem]           (RIP相対・RSP/R12 SIB・RBP/R13 disp8=0 含む)
     PUSH FS / PUSH GS / POP FS / POP GS  (0F A0/A8/A1/A9)
     MOV r64, SEG:[mem]       (6セグメント × 全アドレッシングモード)
     MOV SEG:[mem], r64       (同上 ストア方向)
     LFS / LGS / LSS d,[mem]  (ファーポインタロード 0F B4/B5/B2)


   追加 (v7.0):
     x86_64-v3 対応強化:
     BMI1/BMI2: ANDN, BEXTR, BLSI, BLSMSK, BLSR, BZHI, MULX, PDEP, PEXT, RORX, SARX, SHLX, SHRX
     LZCNT / TZCNT (64/32/16bit)
     AVX/AVX2/FMA3 の全アドレッシングモード完全網羅版

   追加 (v6.0):
     SSE3: ADDSUBPD/PS, HADDPD/PS, HSUBPD/PS, MOVDDUP,
           MOVSLDUP, MOVSHDUP, LDDQU, MONITOR, MWAIT
     SSE4.2: CRC32 (64/32/8bit src)
     RDRAND / RDSEED (64/32/16bit)
     MOVBE (load/store, 64/32bit)
     SIB scale=1: [b+r*1] 全パターン
     ALU store方向: ADD/SUB/AND/OR/XOR [b+r*scale],s

   アドレッシングモード一覧:
     d,s          : レジスタ直接
     d,!i         : 即値 (imm32)
     d8 d,!i      : 即値 (imm8 符号拡張)
     d,[b]        : レジスタ間接
     d,[b+!o]B    : ベース+disp8
     d,[b+!o]     : ベース+disp32
     d,[RIP+!a]   : RIP相対
     [b],s        : メモリ→レジスタ(store)
     [b+!o]B,s    : disp8 store
     [b+!o],s     : disp32 store
     SIZE [b],!i  : メモリに即値

   SIZE修飾子: QWORD/DWORD/WORD/BYTE
   注: RSP(4)/R12(12)ベースはSIB必要(別途)
   ======================================== */

/* ====================== レジスタ定義 ====================== */
.setsym::RAX::0
.setsym::RCX::1
.setsym::RDX::2
.setsym::RBX::3
.setsym::RSP::4
.setsym::RBP::5
.setsym::RSI::6
.setsym::RDI::7
.setsym::R8::8
.setsym::R9::9
.setsym::R10::10
.setsym::R11::11
.setsym::R12::12
.setsym::R13::13
.setsym::R14::14
.setsym::R15::15

.setsym::EAX::0
