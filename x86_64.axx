/* [削除] x86にTEST8は存在しない: TEST8 QWORD [b+!o],!i    ::  ::  0x48|((b&8)>>3),0x83,0x80|(b&7),@@[4,*(o,%%)], (i&0xff) */
/* INC 8-bit */
INC j              ::  ::  ;((j&8)?0x41:0),0xfe,0xc0|(j&7)
INC BYTE [b]            ::  ::  ;((b&8)?0x41:0),0xfe,0x00|(b&7)
INC BYTE [b+!o]B        ::  ::  ;((b&8)?0x41:0),0xfe,0x40|(b&7),(o&0xff)
INC BYTE [b+!o]         ::  ::  ;((b&8)?0x41:0),0xfe,0x80|(b&7),@@[4,*(o,%%)]

/* ======================================================== */
/* DEC */
/* ======================================================== */
/* INC 16-bit */
INC n              ::  ::  0x66,;((n&8)?0x41:0),0xff,0xc0|(n&7)
INC WORD [b]            ::  ::  0x66,;((b&8)?0x41:0),0xff,0x00|(b&7)
INC WORD [b+!o]B        ::  ::  0x66,;((b&8)?0x41:0),0xff,0x40|(b&7),(o&0xff)
INC WORD [b+!o]         ::  ::  0x66,;((b&8)?0x41:0),0xff,0x80|(b&7),@@[4,*(o,%%)]
/* INC 32-bit */
INC f             ::  ::  ;((f&8)?0x41:0),0xff,0xc0|(f&7)
INC DWORD [b]           ::  ::  ;((b&8)?0x41:0),0xff,0x00|(b&7)
INC DWORD [b+!o]B       ::  ::  ;((b&8)?0x41:0),0xff,0x40|(b&7),(o&0xff)
INC DWORD [b+!o]        ::  ::  ;((b&8)?0x41:0),0xff,0x80|(b&7),@@[4,*(o,%%)]
/* INC 64-bit */
INC d                   ::  ::  0x48|((d&8)>>3),0xff,0xc0|(d&7)
INC QWORD [b]           ::  ::  0x48|((b&8)>>3),0xff,0x00|(b&7)
INC QWORD [b+!o]B       ::  ::  0x48|((b&8)>>3),0xff,0x40|(b&7),(o&0xff)
INC QWORD [b+!o]        ::  ::  0x48|((b&8)>>3),0xff,0x80|(b&7),@@[4,*(o,%%)]
/* DEC 8-bit */
DEC j              ::  ::  ;((j&8)?0x41:0),0xfe,0xc8|(j&7)
DEC BYTE [b]            ::  ::  ;((b&8)?0x41:0),0xfe,0x08|(b&7)
DEC BYTE [b+!o]B        ::  ::  ;((b&8)?0x41:0),0xfe,0x48|(b&7),(o&0xff)
DEC BYTE [b+!o]         ::  ::  ;((b&8)?0x41:0),0xfe,0x88|(b&7),@@[4,*(o,%%)]

/* ====================== NEG / NOT (全アドレッシングモード) ====================== */
/* ======================================================== */
/* NEG */
/* ======================================================== */
/* DEC 16-bit */
DEC n              ::  ::  0x66,;((n&8)?0x41:0),0xff,0xc8|(n&7)
DEC WORD [b]            ::  ::  0x66,;((b&8)?0x41:0),0xff,0x08|(b&7)
DEC WORD [b+!o]B        ::  ::  0x66,;((b&8)?0x41:0),0xff,0x48|(b&7),(o&0xff)
DEC WORD [b+!o]         ::  ::  0x66,;((b&8)?0x41:0),0xff,0x88|(b&7),@@[4,*(o,%%)]
/* DEC 32-bit */
DEC f             ::  ::  ;((f&8)?0x41:0),0xff,0xc8|(f&7)
DEC DWORD [b]           ::  ::  ;((b&8)?0x41:0),0xff,0x08|(b&7)
DEC DWORD [b+!o]B       ::  ::  ;((b&8)?0x41:0),0xff,0x48|(b&7),(o&0xff)
DEC DWORD [b+!o]        ::  ::  ;((b&8)?0x41:0),0xff,0x88|(b&7),@@[4,*(o,%%)]
/* DEC 64-bit */
DEC d                   ::  ::  0x48|((d&8)>>3),0xff,0xc8|(d&7)
DEC QWORD [b]           ::  ::  0x48|((b&8)>>3),0xff,0x08|(b&7)
DEC QWORD [b+!o]B       ::  ::  0x48|((b&8)>>3),0xff,0x48|(b&7),(o&0xff)
DEC QWORD [b+!o]        ::  ::  0x48|((b&8)>>3),0xff,0x88|(b&7),@@[4,*(o,%%)]
/* NEG 8-bit */
NEG j              ::  ::  ;((j&8)?0x41:0),0xf6,0xd8|(j&7)
NEG BYTE [b]            ::  ::  ;((b&8)?0x41:0),0xf6,0x18|(b&7)
NEG BYTE [b+!o]B        ::  ::  ;((b&8)?0x41:0),0xf6,0x58|(b&7),(o&0xff)
NEG BYTE [b+!o]         ::  ::  ;((b&8)?0x41:0),0xf6,0x98|(b&7),@@[4,*(o,%%)]

/* ======================================================== */
/* NOT */
/* ======================================================== */
/* NEG 16-bit */
NEG n              ::  ::  0x66,;((n&8)?0x41:0),0xf7,0xd8|(n&7)
NEG WORD [b]            ::  ::  0x66,;((b&8)?0x41:0),0xf7,0x18|(b&7)
NEG WORD [b+!o]B        ::  ::  0x66,;((b&8)?0x41:0),0xf7,0x58|(b&7),(o&0xff)
NEG WORD [b+!o]         ::  ::  0x66,;((b&8)?0x41:0),0xf7,0x98|(b&7),@@[4,*(o,%%)]
/* NEG 32-bit */
NEG f             ::  ::  ;((f&8)?0x41:0),0xf7,0xd8|(f&7)
NEG DWORD [b]           ::  ::  ;((b&8)?0x41:0),0xf7,0x18|(b&7)
NEG DWORD [b+!o]B       ::  ::  ;((b&8)?0x41:0),0xf7,0x58|(b&7),(o&0xff)
NEG DWORD [b+!o]        ::  ::  ;((b&8)?0x41:0),0xf7,0x98|(b&7),@@[4,*(o,%%)]
/* NEG 64-bit */
NEG d                   ::  ::  0x48|((d&8)>>3),0xf7,0xd8|(d&7)
NEG QWORD [b]           ::  ::  0x48|((b&8)>>3),0xf7,0x18|(b&7)
NEG QWORD [b+!o]B       ::  ::  0x48|((b&8)>>3),0xf7,0x58|(b&7),(o&0xff)
NEG QWORD [b+!o]        ::  ::  0x48|((b&8)>>3),0xf7,0x98|(b&7),@@[4,*(o,%%)]
/* NOT 8-bit */
NOT j              ::  ::  ;((j&8)?0x41:0),0xf6,0xd0|(j&7)
NOT BYTE [b]            ::  ::  ;((b&8)?0x41:0),0xf6,0x10|(b&7)
NOT BYTE [b+!o]B        ::  ::  ;((b&8)?0x41:0),0xf6,0x50|(b&7),(o&0xff)
NOT BYTE [b+!o]         ::  ::  ;((b&8)?0x41:0),0xf6,0x90|(b&7),@@[4,*(o,%%)]

/* ====================== MUL / IMUL / DIV / IDIV (全アドレッシングモード) ====================== */
/* NOT 16-bit */
NOT n              ::  ::  0x66,;((n&8)?0x41:0),0xf7,0xd0|(n&7)
NOT WORD [b]            ::  ::  0x66,;((b&8)?0x41:0),0xf7,0x10|(b&7)
NOT WORD [b+!o]B        ::  ::  0x66,;((b&8)?0x41:0),0xf7,0x50|(b&7),(o&0xff)
NOT WORD [b+!o]         ::  ::  0x66,;((b&8)?0x41:0),0xf7,0x90|(b&7),@@[4,*(o,%%)]
/* NOT 32-bit */
NOT f             ::  ::  ;((f&8)?0x41:0),0xf7,0xd0|(f&7)
NOT DWORD [b]           ::  ::  ;((b&8)?0x41:0),0xf7,0x10|(b&7)
NOT DWORD [b+!o]B       ::  ::  ;((b&8)?0x41:0),0xf7,0x50|(b&7),(o&0xff)
NOT DWORD [b+!o]        ::  ::  ;((b&8)?0x41:0),0xf7,0x90|(b&7),@@[4,*(o,%%)]
/* NOT 64-bit */
NOT d                   ::  ::  0x48|((d&8)>>3),0xf7,0xd0|(d&7)
NOT QWORD [b]           ::  ::  0x48|((b&8)>>3),0xf7,0x10|(b&7)
NOT QWORD [b+!o]B       ::  ::  0x48|((b&8)>>3),0xf7,0x50|(b&7),(o&0xff)
NOT QWORD [b+!o]        ::  ::  0x48|((b&8)>>3),0xf7,0x90|(b&7),@@[4,*(o,%%)]
/* MUL 8-bit */
MUL k              ::  ::  ;((k&8)?0x41:0),0xf6,0xe0|(k&7)
MUL BYTE [b]            ::  ::  ;((b&8)?0x41:0),0xf6,0x20|(b&7)

/* MUL 16-bit */
MUL m              ::  ::  0x66,;((m&8)?0x41:0),0xf7,0xe0|(m&7)
MUL WORD [b]            ::  ::  0x66,;((b&8)?0x41:0),0xf7,0x20|(b&7)
/* MUL 32-bit */
MUL t             ::  ::  ;((t&8)?0x41:0),0xf7,0xe0|(t&7)
MUL DWORD [b]           ::  ::  ;((b&8)?0x41:0),0xf7,0x20|(b&7)
MUL DWORD [b+!o]B       ::  ::  ;((b&8)?0x41:0),0xf7,0x60|(b&7),(o&0xff)
MUL DWORD [b+!o]        ::  ::  ;((b&8)?0x41:0),0xf7,0xa0|(b&7),@@[4,*(o,%%)]
/* MUL 64-bit */
MUL s                   ::  ::  0x48|((s&8)>>3),0xf7,0xe0|(s&7)
MUL QWORD [b]           ::  ::  0x48|((b&8)>>3),0xf7,0x20|(b&7)
MUL QWORD [b+!o]B       ::  ::  0x48|((b&8)>>3),0xf7,0x60|(b&7),(o&0xff)
MUL QWORD [b+!o]        ::  ::  0x48|((b&8)>>3),0xf7,0xa0|(b&7),@@[4,*(o,%%)]
/* IMUL 8-bit */
IMUL k              ::  ::  ;((k&8)?0x41:0),0xf6,0xe8|(k&7)
IMUL BYTE [b]            ::  ::  ;((b&8)?0x41:0),0xf6,0x28|(b&7)

/* IMUL 16-bit */
IMUL m              ::  ::  0x66,;((m&8)?0x41:0),0xf7,0xe8|(m&7)
IMUL WORD [b]            ::  ::  0x66,;((b&8)?0x41:0),0xf7,0x28|(b&7)
/* IMUL 32-bit */
IMUL t             ::  ::  ;((t&8)?0x41:0),0xf7,0xe8|(t&7)
IMUL DWORD [b]           ::  ::  ;((b&8)?0x41:0),0xf7,0x28|(b&7)
IMUL DWORD [b+!o]B       ::  ::  ;((b&8)?0x41:0),0xf7,0x68|(b&7),(o&0xff)
IMUL DWORD [b+!o]        ::  ::  ;((b&8)?0x41:0),0xf7,0xa8|(b&7),@@[4,*(o,%%)]
/* IMUL 64-bit */
IMUL s                   ::  ::  0x48|((s&8)>>3),0xf7,0xe8|(s&7)
IMUL QWORD [b]           ::  ::  0x48|((b&8)>>3),0xf7,0x28|(b&7)
IMUL QWORD [b+!o]B       ::  ::  0x48|((b&8)>>3),0xf7,0x68|(b&7),(o&0xff)
IMUL QWORD [b+!o]        ::  ::  0x48|((b&8)>>3),0xf7,0xa8|(b&7),@@[4,*(o,%%)]
/* DIV 8-bit */
DIV k              ::  ::  ;((k&8)?0x41:0),0xf6,0xf0|(k&7)
DIV BYTE [b]            ::  ::  ;((b&8)?0x41:0),0xf6,0x30|(b&7)

/* DIV 16-bit */
DIV m              ::  ::  0x66,;((m&8)?0x41:0),0xf7,0xf0|(m&7)
DIV WORD [b]            ::  ::  0x66,;((b&8)?0x41:0),0xf7,0x30|(b&7)
/* DIV 32-bit */
DIV t             ::  ::  ;((t&8)?0x41:0),0xf7,0xf0|(t&7)
DIV DWORD [b]           ::  ::  ;((b&8)?0x41:0),0xf7,0x30|(b&7)
DIV DWORD [b+!o]B       ::  ::  ;((b&8)?0x41:0),0xf7,0x70|(b&7),(o&0xff)
DIV DWORD [b+!o]        ::  ::  ;((b&8)?0x41:0),0xf7,0xb0|(b&7),@@[4,*(o,%%)]
/* DIV 64-bit */
DIV s                   ::  ::  0x48|((s&8)>>3),0xf7,0xf0|(s&7)
DIV QWORD [b]           ::  ::  0x48|((b&8)>>3),0xf7,0x30|(b&7)
DIV QWORD [b+!o]B       ::  ::  0x48|((b&8)>>3),0xf7,0x70|(b&7),(o&0xff)
DIV QWORD [b+!o]        ::  ::  0x48|((b&8)>>3),0xf7,0xb0|(b&7),@@[4,*(o,%%)]
/* IDIV 8-bit */
IDIV k              ::  ::  ;((k&8)?0x41:0),0xf6,0xf8|(k&7)
IDIV BYTE [b]            ::  ::  ;((b&8)?0x41:0),0xf6,0x38|(b&7)

/* IMUL 2オペランド (r, r/m) */
IMUL d,s                ::  ::  0x48|((d&8)>>1)|((s&8)>>3),0x0f,0xaf,0xc0|((d&7)<<3)|(s&7)
IMUL d,[b]              ::  ::  0x48|((d&8)>>1)|((b&8)>>3),0x0f,0xaf,((d&7)<<3)|(b&7)
IMUL d,[RSP+!o]B          ::  ::  0x48|((d&8)>>1)|((4&8)>>3),0x0f,0xaf,0x40|((d&7)<<3), 0x24,(o&0xff)
IMUL d,[R12+!o]B          ::  ::  0x48|((d&8)>>1)|((12&8)>>3),0x0f,0xaf,0x40|((d&7)<<3), 0x24,(o&0xff)
IMUL d,[b+!o]B          ::  ::  0x48|((d&8)>>1)|((b&8)>>3),0x0f,0xaf,0x40|((d&7)<<3)|(b&7),(o&0xff)
IMUL d,[RSP+!o]           ::  ::  0x48|((d&8)>>1)|((4&8)>>3),0x0f,0xaf,0x80|((d&7)<<3), 0x24,@@[4,*(o,%%)]
IMUL d,[R12+!o]           ::  ::  0x48|((d&8)>>1)|((12&8)>>3),0x0f,0xaf,0x80|((d&7)<<3), 0x24,@@[4,*(o,%%)]
IMUL d,[b+!o]           ::  ::  0x48|((d&8)>>1)|((b&8)>>3),0x0f,0xaf,0x80|((d&7)<<3)|(b&7),@@[4,*(o,%%)]
IMUL f,t          ::  ::  ;(((f|t)&8)?(0x40|((f&8)>>1)|((t&8)>>3)):0),0x0f,0xaf,0xc0|((f&7)<<3)|(t&7)
IMUL f,[b]        ::  ::  ;(((f|b)&8)?(0x40|((f&8)>>1)|((b&8)>>3)):0),0x0f,0xaf,((f&7)<<3)|(b&7)
IMUL f,[RSP+!o]B    ::  ::  ;(((f|4)&8)?(0x40|((f&8)>>1)|((4&8)>>3)):0),0x0f,0xaf,0x40|((f&7)<<3), 0x24,(o&0xff)
IMUL f,[R12+!o]B    ::  ::  ;(((f|12)&8)?(0x40|((f&8)>>1)|((12&8)>>3)):0),0x0f,0xaf,0x40|((f&7)<<3), 0x24,(o&0xff)
IMUL f,[b+!o]B    ::  ::  ;(((f|b)&8)?(0x40|((f&8)>>1)|((b&8)>>3)):0),0x0f,0xaf,0x40|((f&7)<<3)|(b&7),(o&0xff)
IMUL f,[RSP+!o]     ::  ::  ;(((f|4)&8)?(0x40|((f&8)>>1)|((4&8)>>3)):0),0x0f,0xaf,0x80|((f&7)<<3), 0x24,@@[4,*(o,%%)]
IMUL f,[R12+!o]     ::  ::  ;(((f|12)&8)?(0x40|((f&8)>>1)|((12&8)>>3)):0),0x0f,0xaf,0x80|((f&7)<<3), 0x24,@@[4,*(o,%%)]
IMUL f,[b+!o]     ::  ::  ;(((f|b)&8)?(0x40|((f&8)>>1)|((b&8)>>3)):0),0x0f,0xaf,0x80|((f&7)<<3)|(b&7),@@[4,*(o,%%)]
/* IMUL 3オペランド */
IMUL d,s,!i             ::  ::  0x48|((d&8)>>1)|((s&8)>>3),0x69,0xc0|((d&7)<<3)|(s&7),@@[4,*(i,%%)]
IMUL8 d,s,!i            ::  ::  0x48|((d&8)>>1)|((s&8)>>3),0x6b,0xc0|((d&7)<<3)|(s&7),(i&0xff)
IMUL d,[b],!i           ::  ::  0x48|((d&8)>>1)|((b&8)>>3),0x69,((d&7)<<3)|(b&7),@@[4,*(i,%%)]
IMUL8 d,[b],!i          ::  ::  0x48|((d&8)>>1)|((b&8)>>3),0x6b,((d&7)<<3)|(b&7),(i&0xff)

/* ====================== シフト / ローテート (全アドレッシングモード) ====================== */
/* ROL */
/* CLを!iより先に定義 (CLの番号=1がimm8にマッチするため) */
ROL j,CL          ::  ::  ;((j&8)?0x41:0),0xd2,0xc0|(j&7)
ROL j,1           ::  ::  ;((j&8)?0x41:0),0xd0,0xc0|(j&7)
ROL j,!i          ::  ::  ;((j&8)?0x41:0),0xc0,0xc0|(j&7),(i&0xff)
ROL BYTE [b],CL        ::  ::  ;((b&8)?0x41:0),0xd2,0x00|(b&7)
ROL BYTE [b],1         ::  ::  ;((b&8)?0x41:0),0xd0,0x00|(b&7)
ROL BYTE [b],!i        ::  ::  ;((b&8)?0x41:0),0xc0,0x00|(b&7),(i&0xff)
ROL BYTE [b+!o]B,CL    ::  ::  ;((b&8)?0x41:0),0xd2,0x40|(b&7),(o&0xff)
ROL BYTE [b+!o]B,!i    ::  ::  ;((b&8)?0x41:0),0xc0,0x40|(b&7),(o&0xff),(i&0xff)

/* ROR */
/* CLを!iより先に定義 (CLの番号=1がimm8にマッチするため) */
ROL n,CL          ::  ::  0x66,;((n&8)?0x41:0),0xd3,0xc0|(n&7)
ROL n,1           ::  ::  0x66,;((n&8)?0x41:0),0xd1,0xc0|(n&7)
ROL n,!i          ::  ::  0x66,;((n&8)?0x41:0),0xc1,0xc0|(n&7),(i&0xff)
ROL WORD [b],CL        ::  ::  0x66,;((b&8)?0x41:0),0xd3,0x00|(b&7)
ROL WORD [b],1         ::  ::  0x66,;((b&8)?0x41:0),0xd1,0x00|(b&7)
ROL WORD [b],!i        ::  ::  0x66,;((b&8)?0x41:0),0xc1,0x00|(b&7),(i&0xff)
ROL WORD [b+!o]B,CL    ::  ::  0x66,;((b&8)?0x41:0),0xd3,0x40|(b&7),(o&0xff)
ROL WORD [b+!o]B,!i    ::  ::  0x66,;((b&8)?0x41:0),0xc1,0x40|(b&7),(o&0xff),(i&0xff)
ROL f,CL         ::  ::  ;((f&8)?0x41:0),0xd3,0xc0|(f&7)
ROL f,1          ::  ::  ;((f&8)?0x41:0),0xd1,0xc0|(f&7)
ROL f,!i         ::  ::  ;((f&8)?0x41:0),0xc1,0xc0|(f&7),(i&0xff)
ROL DWORD [b],CL       ::  ::  ;((b&8)?0x41:0),0xd3,0x00|(b&7)
ROL DWORD [b],1        ::  ::  ;((b&8)?0x41:0),0xd1,0x00|(b&7)
ROL DWORD [b],!i       ::  ::  ;((b&8)?0x41:0),0xc1,0x00|(b&7),(i&0xff)
ROL DWORD [b+!o]B,CL   ::  ::  ;((b&8)?0x41:0),0xd3,0x40|(b&7),(o&0xff)
ROL DWORD [b+!o]B,1    ::  ::  ;((b&8)?0x41:0),0xd1,0x40|(b&7),(o&0xff)
ROL DWORD [b+!o]B,!i   ::  ::  ;((b&8)?0x41:0),0xc1,0x40|(b&7),(o&0xff),(i&0xff)
ROL DWORD [b+!o],CL    ::  ::  ;((b&8)?0x41:0),0xd3,0x80|(b&7),@@[4,*(o,%%)]
ROL DWORD [b+!o],1     ::  ::  ;((b&8)?0x41:0),0xd1,0x80|(b&7),@@[4,*(o,%%)]
ROL DWORD [b+!o],!i    ::  ::  ;((b&8)?0x41:0),0xc1,0x80|(b&7),@@[4,*(o,%%)], (i&0xff)
ROL d,CL               ::  ::  0x48|((d&8)>>3),0xd3,0xc0|(d&7)
ROL d,1                ::  ::  0x48|((d&8)>>3),0xd1,0xc0|(d&7)
ROL d,!i               ::  ::  0x48|((d&8)>>3),0xc1,0xc0|(d&7),(i&0xff)
ROL QWORD [b],CL       ::  ::  0x48|((b&8)>>3),0xd3,0x00|(b&7)
ROL QWORD [b],1        ::  ::  0x48|((b&8)>>3),0xd1,0x00|(b&7)
ROL QWORD [b],!i       ::  ::  0x48|((b&8)>>3),0xc1,0x00|(b&7),(i&0xff)
ROL QWORD [b+!o]B,CL   ::  ::  0x48|((b&8)>>3),0xd3,0x40|(b&7),(o&0xff)
ROL QWORD [b+!o]B,1    ::  ::  0x48|((b&8)>>3),0xd1,0x40|(b&7),(o&0xff)
ROL QWORD [b+!o]B,!i   ::  ::  0x48|((b&8)>>3),0xc1,0x40|(b&7),(o&0xff),(i&0xff)
