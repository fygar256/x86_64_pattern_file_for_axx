LSS d,[b]        ::  ::  0x48|((d&8)>>1)|((b&8)>>3),0x0f,0xb2,((d&7)<<3)|(b&7)
LSS d,[RSP+!o]B  ::  ::  0x48|((d&8)>>1),0x0f,0xb2,0x40|((d&7)<<3)|0x04,0x24,(o&0xff)
LSS d,[R12+!o]B  ::  ::  0x49|((d&8)>>1),0x0f,0xb2,0x40|((d&7)<<3)|0x04,0x24,(o&0xff)
LSS d,[b+!o]B    ::  ::  0x48|((d&8)>>1)|((b&8)>>3),0x0f,0xb2,0x40|((d&7)<<3)|(b&7),(o&0xff)
LSS d,[RSP+!o]   ::  ::  0x48|((d&8)>>1),0x0f,0xb2,0x80|((d&7)<<3)|0x04,0x24,@@[4,*(o,%%)]
LSS d,[R12+!o]   ::  ::  0x49|((d&8)>>1),0x0f,0xb2,0x80|((d&7)<<3)|0x04,0x24,@@[4,*(o,%%)]
LSS d,[b+!o]     ::  ::  0x48|((d&8)>>1)|((b&8)>>3),0x0f,0xb2,0x80|((d&7)<<3)|(b&7),@@[4,*(o,%%)]


/* =========================================================
   v9.0 追加: セグメントオーバーライド付き DWORD/WORD/BYTE MOV
   =========================================================
   64ビット版 (QWORD) は v8.0 で追加済み。
   DWORD: REX.W なし、条件付き REX (d/s/b >= 8 の場合)
   WORD : 0x66 + 条件付き REX
   BYTE : 条件付き REX (0x8A ロード / 0x88 ストア)
   ========================================================= */


/* MOV DWORD d,ES:[mem]  (opcode=0x8B, 条件付きREX) */
MOV j,p:[RSP]       ::  ::  (p<4)?(0x26|(p<<3)):(0x60|(p&7)),;((j&8)?0x44:0),0x8a,((j&7)<<3)|4,0x24
MOV j,p:[R12]       ::  ::  (p<4)?(0x26|(p<<3)):(0x60|(p&7)),0x41|((j&8)>>1),0x8a,((j&7)<<3)|4,0x24
MOV j,p:[RBP]       ::  ::  (p<4)?(0x26|(p<<3)):(0x60|(p&7)),;((j&8)?0x44:0),0x8a,0x40|((j&7)<<3)|5,0x00
MOV j,p:[R13]       ::  ::  (p<4)?(0x26|(p<<3)):(0x60|(p&7)),0x41|((j&8)>>1),0x8a,0x40|((j&7)<<3)|5,0x00
MOV j,p:[b]         ::  ::  (p<4)?(0x26|(p<<3)):(0x60|(p&7)),;(((j|b)&8)?(0x40|((j&8)>>1)|((b&8)>>3)):0),0x8a,((j&7)<<3)|(b&7)
MOV j,p:[b+!o]B     ::  ::  (p<4)?(0x26|(p<<3)):(0x60|(p&7)),;(((j|b)&8)?(0x40|((j&8)>>1)|((b&8)>>3)):0),0x8a,0x40|((j&7)<<3)|(b&7),(o&0xff)
MOV j,p:[b+!o]      ::  ::  (p<4)?(0x26|(p<<3)):(0x60|(p&7)),;(((j|b)&8)?(0x40|((j&8)>>1)|((b&8)>>3)):0),0x8a,0x80|((j&7)<<3)|(b&7),@@[4,*(o,%%)]

/* MOV BYTE ES:[mem],s  (opcode=0x88) */
MOV p:[RSP],k       ::  ::  (p<4)?(0x26|(p<<3)):(0x60|(p&7)),;((k&8)?0x44:0),0x88,((k&7)<<3)|4,0x24
MOV p:[R12],k       ::  ::  (p<4)?(0x26|(p<<3)):(0x60|(p&7)),0x41|((k&8)>>1),0x88,((k&7)<<3)|4,0x24
MOV p:[RBP],k       ::  ::  (p<4)?(0x26|(p<<3)):(0x60|(p&7)),;((k&8)?0x44:0),0x88,0x40|((k&7)<<3)|5,0x00
MOV p:[R13],k       ::  ::  (p<4)?(0x26|(p<<3)):(0x60|(p&7)),0x41|((k&8)>>1),0x88,0x40|((k&7)<<3)|5,0x00
MOV p:[b],k         ::  ::  (p<4)?(0x26|(p<<3)):(0x60|(p&7)),;(((k|b)&8)?(0x40|((k&8)>>1)|((b&8)>>3)):0),0x88,((k&7)<<3)|(b&7)
MOV p:[b+!o]B,k     ::  ::  (p<4)?(0x26|(p<<3)):(0x60|(p&7)),;(((k|b)&8)?(0x40|((k&8)>>1)|((b&8)>>3)):0),0x88,0x40|((k&7)<<3)|(b&7),(o&0xff)
MOV p:[b+!o],k      ::  ::  (p<4)?(0x26|(p<<3)):(0x60|(p&7)),;(((k|b)&8)?(0x40|((k&8)>>1)|((b&8)>>3)):0),0x88,0x80|((k&7)<<3)|(b&7),@@[4,*(o,%%)]

/* MOV SEG:[mem],imm (即値ストア) */
MOV BYTE p:[RSP],!i      ::  ::  (p<4)?(0x26|(p<<3)):(0x60|(p&7)),0xc6,0x04,0x24,(i&0xff)
MOV BYTE p:[R12],!i      ::  ::  (p<4)?(0x26|(p<<3)):(0x60|(p&7)),0x41,0xc6,0x04,0x24,(i&0xff)
MOV BYTE p:[RBP],!i      ::  ::  (p<4)?(0x26|(p<<3)):(0x60|(p&7)),0xc6,0x45,0x00,(i&0xff)
MOV BYTE p:[R13],!i      ::  ::  (p<4)?(0x26|(p<<3)):(0x60|(p&7)),0x41,0xc6,0x45,0x00,(i&0xff)
MOV BYTE p:[b],!i        ::  ::  (p<4)?(0x26|(p<<3)):(0x60|(p&7)),;((b&8)?0x41:0),0xc6,(b&7),(i&0xff)
MOV BYTE p:[b+!o]B,!i    ::  ::  (p<4)?(0x26|(p<<3)):(0x60|(p&7)),;((b&8)?0x41:0),0xc6,0x40|(b&7),(o&0xff),(i&0xff)
MOV BYTE p:[b+!o],!i     ::  ::  (p<4)?(0x26|(p<<3)):(0x60|(p&7)),;((b&8)?0x41:0),0xc6,0x80|(b&7),@@[4,*(o,%%)],  (i&0xff)
