/* ★ 順序重要: MOV d,s (汎用 r64←r64) より前に配置 ★
   MOV sreg,r  : 0x8E /r  ModRM = 11 sreg_num reg
   MOV r,sreg  : 0x8C /r  ModRM = 11 sreg_num reg
   d>=8 (R8-R15) の場合は REX.B=1 (0x41) が必要。                   */

