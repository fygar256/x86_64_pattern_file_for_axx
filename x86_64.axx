PREFETCHNTA [b]         ::  ::  ;((b&8)?0x41:0),0x0f,0x18,0x00|(b&7)

/* ====================== IN / OUT ====================== */
IN AL,DX                ::  ::  0xec
IN AX,DX                ::  ::  0x66,0xed
IN EAX,DX               ::  ::  0xed
IN AL,!i                ::  ::  0xe4,(i&0xff)
IN EAX,!i               ::  ::  0xe5,(i&0xff)
OUT DX,AL               ::  ::  0xee
OUT DX,EAX              ::  ::  0xef
OUT !i,AL               ::  ::  0xe6,(i&0xff)
OUT !i,EAX              ::  ::  0xe7,(i&0xff)

/* ====================== セグメント / CR / DR ====================== */
MOV FS,d                ::  ::  ;((d&8)?0x41:0),0x8e,0xe0|(d&7)
MOV GS,d                ::  ::  ;((d&8)?0x41:0),0x8e,0xe8|(d&7)
