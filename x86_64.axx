/* ====================== XCHG / CMPXCHG / XADD (全アドレッシングモード) ====================== */
BSWAP d                 ::  ::  0x48|((d&8)>>3),0x0f,0xc8|(d&7)
XCHG f,t          ::  ::  ;(((t|f)&8)?(0x40|((t&8)>>1)|((f&8)>>3)):0),0x87,0xc0|(f&7)|((t&7)<<3)
