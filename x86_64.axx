INT3                    ::  ::  0xcc
INT !i                  ::  ::  0xcd,(i&0xff)
INTO                    ::  ::  0xce
IRETQ                   ::  ::  0x48,0xcf
IRETD                   ::  ::  0xcf
LEAVE                   ::  ::  0xc9
ENTER !c,!l             ::  ::  0xc8,@@[2,*(c,%%)], (l&0xff)
